# Database — use file:./dev.db for local SQLite
# On Railway: set DATABASE_URL to your Railway-provided PostgreSQL URL (optional upgrade)
DATABASE_URL="file:./dev.db"

# JWT Secret — change this to a strong random string in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Port — Railway sets this automatically via $PORT env var
PORT=4000

# Environment
NODE_ENV="development"
